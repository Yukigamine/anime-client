generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum WatchStatus {
  WATCHING
  PLAN_TO_WATCH
  COMPLETED
  ON_HOLD
  DROPPED
}

enum ReadStatus {
  READING
  PLAN_TO_READ
  COMPLETED
  ON_HOLD
  DROPPED
}

enum ShowStatus {
  AIRING
  FINISHED
  UPCOMING
  CANCELLED
  UNKNOWN
}

enum Provider {
  KITSU
  ANILIST
}

enum SyncStatus {
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum SyncDirection {
  PULL
  PUSH
}

enum MediaFormat {
  DVD
  BLU_RAY
  VHS
  DIGITAL
  OTHER
}

enum CollectionCondition {
  MINT
  NEAR_MINT
  GOOD
  FAIR
  POOR
}

enum CollectionRarity {
  STEELBOOK
  DELUXE
  LIMITED
  COLLECTORS
  STANDARD
}

enum MangaLanguage {
  ENGLISH
  JAPANESE
  OTHER
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model AuthToken {
  id             String    @id @default(cuid())
  provider       Provider  @unique
  accessToken    String
  refreshToken   String?
  expiresAt      DateTime?
  providerUserId String?
  username       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// BetterAuth session management tables

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
  @@index([userId])
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
  @@index([userId])
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── Sync Logs ────────────────────────────────────────────────────────────────

model SyncLog {
  id            String        @id @default(cuid())
  provider      Provider
  direction     SyncDirection
  status        SyncStatus    @default(RUNNING)
  animeSynced   Int           @default(0)
  mangaSynced   Int           @default(0)
  animeChanged  Int           @default(0)
  mangaChanged  Int           @default(0)
  errors        Json          @default("[]")
  deletions     Json          @default("[]")
  startedAt     DateTime      @default(now())
  finishedAt    DateTime?
}

// ─── Anime ────────────────────────────────────────────────────────────────────

model Anime {
  id             String     @id @default(cuid())
  kitsuId        String?    @unique
  anilistId      Int?       @unique
  malId          Int?       @unique

  titleEn        String?
  titleJp        String?
  titleRomaji    String?
  synopsis       String?
  coverImageUrl  String?
  bannerImageUrl String?
  episodeCount   Int?
  showStatus     ShowStatus @default(UNKNOWN)
  averageRating  Float?
  startDate      DateTime?
  endDate        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listEntry       AnimeListEntry?
  collectionItems AnimeCollectionItem[]
}

model AnimeListEntry {
  id      String @id @default(cuid())
  animeId String @unique
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  watchStatus  WatchStatus
  progress     Int         @default(0)
  rating       Float?
  notes        String?
  private      Boolean     @default(false)
  rewatchCount Int         @default(0)
  rewatching   Boolean     @default(false)

  kitsuEntryId   String?
  anilistEntryId Int?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime?
}

model AnimeCollectionItem {
  id      String @id @default(cuid())
  animeId String
  anime   Anime  @relation(fields: [animeId], references: [id], onDelete: Cascade)

  rarity      CollectionRarity    @default(STANDARD)
  format      MediaFormat         @default(BLU_RAY)
  condition   CollectionCondition @default(GOOD)
  notes       String?
  purchasedAt DateTime?
  pricePaid   Float?
  barcode     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Manga ────────────────────────────────────────────────────────────────────

model Manga {
  id             String     @id @default(cuid())
  kitsuId        String?    @unique
  anilistId      Int?       @unique
  malId          Int?       @unique

  titleEn        String?
  titleJp        String?
  titleRomaji    String?
  synopsis       String?
  coverImageUrl  String?
  chapterCount   Int?
  volumeCount    Int?
  showStatus     ShowStatus @default(UNKNOWN)
  averageRating  Float?
  startDate      DateTime?
  endDate        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listEntry       MangaListEntry?
  collectionItems MangaCollectionItem[]
}

model MangaListEntry {
  id      String @id @default(cuid())
  mangaId String @unique
  manga   Manga  @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  readStatus      ReadStatus
  progress        Int        @default(0)
  progressVolumes Int        @default(0)
  rating          Float?
  notes           String?
  private         Boolean    @default(false)
  rereadCount     Int        @default(0)
  rereading       Boolean    @default(false)

  kitsuEntryId   String?
  anilistEntryId Int?

  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime?
}

model MangaCollectionItem {
  id      String @id @default(cuid())
  mangaId String
  manga   Manga  @relation(fields: [mangaId], references: [id], onDelete: Cascade)

  condition           CollectionCondition @default(GOOD)
  language            MangaLanguage       @default(ENGLISH)
  notes               String?
  containsSerialized  Boolean             @default(false)
  containsOmnibus     Boolean             @default(false)
  volumes             Int[]
  chapters            Int[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
