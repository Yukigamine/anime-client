# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres – pooled (runtime) and direct (migrations)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Vercel KV (Redis) ────────────────────────────────────────────────────────
# Copy from Vercel dashboard → Storage → KV → .env.local
KV_URL="redis://..."
KV_REST_API_URL="https://..."
KV_REST_API_TOKEN="..."
KV_REST_API_READ_ONLY_TOKEN="..."

# ─── Kitsu OAuth ──────────────────────────────────────────────────────────────
# Register your app at https://kitsu.io/settings/apps to get your own credentials.
# The values below are Kitsu's public web client credentials (widely used by 3rd-party apps).
KITSU_CLIENT_ID="dd031b32d2f56c990b1425efe6c42ad847e7be3fd1d1f097b730ac4e9f63de41"
KITSU_CLIENT_SECRET="54d7307928f63414defd96399fc31ba847961ceaecef3a5fd93144e960c0e151"

# ─── AniList OAuth ────────────────────────────────────────────────────────────
# Register your app at https://anilist.co/settings/developer
# Set the redirect URL to: https://yourdomain.com/login/anilist/callback
ANILIST_CLIENT_ID="your_anilist_client_id"
ANILIST_CLIENT_SECRET="your_anilist_client_secret"
ANILIST_REDIRECT_URI="http://localhost:3000/login/anilist/callback"

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL used to build OAuth redirect URIs (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cookie signing secret – generate with: openssl rand -hex 32
TOKEN_COOKIE_SECRET="change-me-to-a-random-32-char-hex-string"

# Optional: protect sync API routes with a shared secret
SYNC_SECRET="change-me"
