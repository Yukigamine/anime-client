# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres – pooled (runtime) and direct (migrations)
POSTGRES_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Redis connection URL (Upstash, Railway, or any redis:// compatible provider)
REDIS_URL=

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL used to build OAuth redirect URIs (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── BetterAuth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET="change-me-to-a-random-32-char-hex-string"
# URL of this app (same as NEXT_PUBLIC_APP_URL, required by BetterAuth internally)
BETTER_AUTH_URL="http://localhost:3000"

# Only this email address will be allowed to sign in.
# Leave blank to allow any authenticated email (not recommended for public deployments).
AUTHORIZED_EMAIL="you@example.com"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/apis/credentials
# Callback URL: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Discord OAuth ────────────────────────────────────────────────────────────
# Register at https://discord.com/developers/applications
# Callback URL: https://yourdomain.com/api/auth/callback/discord
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Register at https://github.com/settings/developers
# Callback URL: https://yourdomain.com/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Twitter / X OAuth ────────────────────────────────────────────────────────
# Register at https://developer.twitter.com/en/portal/dashboard
# Callback URL: https://yourdomain.com/api/auth/callback/twitter
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# ─── Custom OAuth Provider (optional) ────────────────────────────────────────
# Any OAuth 2.0 / OIDC provider (e.g., Authentik, Keycloak, Auth0, etc.)
# Callback URL: https://yourdomain.com/api/auth/oauth2/callback/oauth
CUSTOM_OAUTH_CLIENT_ID=
CUSTOM_OAUTH_CLIENT_SECRET=
# OPTION 1: Use discoveryUrl for OIDC providers (automatic endpoint discovery)
CUSTOM_OAUTH_DISCOVERY_URL=
# OPTION 2: Manually specify endpoints (for non-OIDC or custom providers)
# If discoveryUrl is set, these are ignored
CUSTOM_OAUTH_AUTHORIZATION_URL=
CUSTOM_OAUTH_TOKEN_URL=
CUSTOM_OAUTH_USERINFO_URL=
# Display name shown on the login button
CUSTOM_OAUTH_NAME="My Provider"
# Optional icon URL shown on the login button (leave blank for a globe icon)
CUSTOM_OAUTH_ICON=

# ─── AniList OAuth ────────────────────────────────────────────────────────────
# Register your app at https://anilist.co/settings/developer
# Callback URL: https://yourdomain.com/link/anilist/callback
ANILIST_CLIENT_ID="your_anilist_client_id"
ANILIST_CLIENT_SECRET="your_anilist_client_secret"
ANILIST_REDIRECT_URI="http://localhost:3000/link/anilist/callback"

# ─── External API endpoints ───────────────────────────────────────────────────
KITSU_API_URL="https://kitsu.app/api/graphql"
NEXT_PUBLIC_KITSU_API_URL="https://kitsu.app/api/graphql"
KITSU_OAUTH_URL="https://kitsu.app/api/oauth/token"
ANILIST_API_URL="https://graphql.anilist.co"

# ─── Profile usernames ────────────────────────────────────────────────────────
# Public usernames used to display /me without requiring login.
# Also prefilled on the login form; login is rejected if a different account is used.
NEXT_PUBLIC_KITSU_USERNAME=""
NEXT_PUBLIC_ANILIST_USERNAME=""

# Cookie signing secret – generate with: openssl rand -hex 32
TOKEN_COOKIE_SECRET="change-me-to-a-random-32-char-hex-string"

# Optional: protect sync API routes with a shared secret
SYNC_SECRET="change-me"

