# ─── Database ─────────────────────────────────────────────────────────────────
# Neon Postgres – pooled (runtime) and direct (migrations)
POSTGRES_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── Vercel KV (Redis) ────────────────────────────────────────────────────────
# Copy from Vercel dashboard → Storage → KV → .env.local
KV_URL="redis://..."
KV_REST_API_URL="https://..."
KV_REST_API_TOKEN="..."
KV_REST_API_READ_ONLY_TOKEN="..."

# ─── AniList OAuth ────────────────────────────────────────────────────────────
# Register your app at https://anilist.co/settings/developer
# Set the redirect URL to: https://yourdomain.com/link/anilist/callback
ANILIST_CLIENT_ID="your_anilist_client_id"
ANILIST_CLIENT_SECRET="your_anilist_client_secret"
ANILIST_REDIRECT_URI="http://localhost:3000/link/anilist/callback"

# ─── External API endpoints ───────────────────────────────────────────────────
KITSU_API_URL="https://kitsu.app/api/graphql"
NEXT_PUBLIC_KITSU_API_URL="https://kitsu.app/api/graphql"
KITSU_OAUTH_URL="https://kitsu.app/api/oauth/token"
ANILIST_API_URL="https://graphql.anilist.co"

# ─── Profile usernames ────────────────────────────────────────────────────────
# Public usernames used to display /me without requiring login.
# Also prefilled on the login form; login is rejected if a different account is used.
NEXT_PUBLIC_KITSU_USERNAME=""
NEXT_PUBLIC_ANILIST_USERNAME=""

# ─── App ──────────────────────────────────────────────────────────────────────
# Base URL used to build OAuth redirect URIs (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cookie signing secret – generate with: openssl rand -hex 32
TOKEN_COOKIE_SECRET="change-me-to-a-random-32-char-hex-string"

# Optional: protect sync API routes with a shared secret
SYNC_SECRET="change-me"
