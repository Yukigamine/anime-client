# Neon Postgres – pooled connection (used at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Neon Postgres – direct connection (used for migrations)
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Vercel KV (Redis) – copy from Vercel dashboard → Storage → KV → .env.local
KV_URL="redis://..."
KV_REST_API_URL="https://..."
KV_REST_API_TOKEN="..."
KV_REST_API_READ_ONLY_TOKEN="..."

# Kitsu – username of the account whose list to sync
KITSU_USERNAME="your_kitsu_username"

# AniList – username of the account whose list to sync
ANILIST_USERNAME="your_anilist_username"

# Optional: secret token to protect the /api/sync/* routes
SYNC_SECRET="change-me"
