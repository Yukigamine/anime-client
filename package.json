{
  "name": "anime-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "biome lint --write",
    "lint-check": "biome check && knip",
    "lint-staged": "lint-staged",
    "format": "biome format --write",
    "check": "biome check --write",
    "knip": "knip",
    "knip:deps": "knip --dependencies",
    "prepare": "prisma generate && husky",
    "deploy": "prisma generate && prisma migrate deploy && next build",
    "db-edit": "prisma studio",
    "db-init": "prisma migrate reset",
    "zeus:kitsu": "tsx scripts/zeus-gen.ts https://kitsu.app/api/graphql src/lib/zeus/kitsu --graphql=graphql/kitsu.schema.graphql",
    "zeus:anilist": "tsx scripts/zeus-gen.ts https://graphql.anilist.co src/lib/zeus/anilist --graphql=graphql/anilist.schema.graphql"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/material-nextjs": "9.0.1",
    "@neondatabase/serverless": "1.1.0",
    "@prisma/adapter-neon": "7.8.0",
    "@prisma/client": "7.8.0",
    "@vercel/kv": "3.0.0",
    "next": "16.2.5",
    "notistack": "3.0.2",
    "prisma": "7.8.0",
    "puppeteer": "24.43.0",
    "puppeteer-extra": "3.3.6",
    "puppeteer-extra-plugin-stealth": "2.11.2",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shallow-clone": "3.0.1",
    "swr": "2.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-conventional": "20.5.3",
    "@commitlint/types": "20.5.0",
    "@prisma/adapter-pg": "7.8.0",
    "@types/node": "25.6.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.4.2",
    "graphql-zeus": "7.2.1",
    "husky": "9.1.7",
    "knip": "6.12.1",
    "lint-staged": "16.4.0",
    "server-only": "0.0.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3"
  },
  "packageManager": "pnpm@10.33.4",
  "pnpm": {
    "onlyBuiltDependencies": [
      "puppeteer"
    ]
  }
}
